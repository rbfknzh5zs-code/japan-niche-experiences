# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The address that will receive reservation request emails
SITE_OWNER_EMAIL=you@example.com

# The "from" address used when sending emails (must be a verified Resend domain)
EMAIL_FROM=Digital Detox Japan <noreply@yourdomain.com>

# ─── AI (OpenAI) ─────────────────────────────────────────────────────────────
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx

# Default model for internal reservation summaries
OPENAI_MODEL=gpt-5.4

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used for canonical URLs, sitemap, and OG tags
NEXT_PUBLIC_SITE_URL=https://digitaldetoxjapan.com

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
